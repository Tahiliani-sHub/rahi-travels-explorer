# Database
# Local dev (PostgreSQL): postgresql://user:password@localhost:5432/rahi_travels
# Railway: automatically set when you add a PostgreSQL plugin — copy from Railway dashboard
DATABASE_URL="postgresql://user:password@localhost:5432/rahi_travels"

# Payment processing (Razorpay)
# Get test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
VITE_RAZORPAY_KEY_ID="rzp_test_your_key_id"

# Email delivery (Resend)
RESEND_API_KEY="your_resend_api_key"
SENDER_EMAIL="bookings@rahitravels.tn"

# Flight Search (Duffel)
DUFFEL_API_KEY="your_duffel_api_key"
